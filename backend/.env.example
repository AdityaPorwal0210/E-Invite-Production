# Server Configuration
PORT=5000

# MongoDB Connection
MONGO_URI=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/invite_app?retryWrites=true&w=majority

# JWT Authentication
JWT_SECRET=your_jwt_secret_key_here

# Cloudinary (Image Upload)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email Service (Brevo/Sendinblue)
BREVO_API_KEY=your_brevo_api_key
BREVO_SENDER_EMAIL=noreply@yourdomain.com
BREVO_SENDER_NAME=E-Invite

# Frontend URL (Web App)
# For local development: http://localhost:5173
# For network testing: http://YOUR_LOCAL_IP:5173 (e.g., http://192.168.1.100:5173)
FRONTEND_URL=http://localhost:5173

# Mobile App URL Scheme (Expo Go)
# For local Expo Go testing: exp://YOUR_LOCAL_IP:8081
# For production: exp://exp.host/@username/project-name
# Example: exp://192.168.1.100:8081
MOBILE_APP_URL_SCHEME=exp://YOUR_LOCAL_IP:8081

# Google OAuth (Frontend only)
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
